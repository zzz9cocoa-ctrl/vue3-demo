# API基础URL
VITE_API_BASE_URL=http://localhost:3001/api

# 应用标题
VITE_APP_TITLE=Vue3 TypeScript 教学项目

# 应用版本
VITE_APP_VERSION=1.0.0

# 开发模式
VITE_APP_ENV=development

# 是否启用Mock数据
VITE_USE_MOCK=true

# 日志级别
VITE_LOG_LEVEL=debug

# 是否启用PWA
VITE_ENABLE_PWA=false

# 分析工具配置
VITE_ANALYTICS_ID=

# 错误报告服务
VITE_SENTRY_DSN=